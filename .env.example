# Backend Port
BACKEND_PORT=4000

# Frontend URL for CORS
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

# Secret for encryption (use a long random string in production)
APP_SECRET=your-random-secret-key-min-32-characters-long

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, read:user, user:email
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Configuration
# API Key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model to use for code reviews (gpt-4-turbo works best, gpt-3.5-turbo is cheaper)
OPENAI_MODEL=gpt-4.1-mini
